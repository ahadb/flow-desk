# =============================================================================
# Flow Desk — environment template
# =============================================================================
# Canonical local config: copy to **repo-root `.env`** (gitignored). One file
# for both Vite and the Node API.
#
#   cp .env.example .env
#
# Vite reads only repo-root `.env` (see vite.config.ts `envDir`). The server
# loads the same file via server/src/env/bootstrap.ts (path to repo root, not
# `process.cwd()` — so `npm run dev --prefix server` and `db:migrate` still use
# this file even when the shell cwd is `server/`).
#
# If you previously used `server/.env`, merge those variables into `.env` at
# the repo root and remove `server/.env` so you do not assume a second source.
#
# Production (Cloud Run, etc.): set env vars in the platform UI or Secret
# Manager — do not rely on a `.env` file in the image.
#
# Docker (local API container): pass this file at run time, e.g.
#   docker run --rm -p 18080:8080 --env-file .env flowdesk-api
# (see root Dockerfile and `npm run docker:api:*` from repo root).
#
# Vite exposes only variables prefixed with `VITE_` to the browser:
#   https://vitejs.dev/guide/env-and-mode.html
#
# Local vs production:
#   • Local: leave VITE_BLOTTER_* empty to use Vite dev proxy (vite.config.ts)
#     to the API on 127.0.0.1:8000 — same browser origin, no CORS issues.
#   • Production: either serve the SPA from the same host as the API (omit
#     VITE_BLOTTER_*) or set explicit https:// and wss:// URLs below (split
#     origins may require CORS on the server).
#   • NODE_ENV: use `development` locally; Cloud Run / containers should set
#     `production` when you deploy.
# =============================================================================

# --- Runtime (optional) ------------------------------------------------------
# NODE_ENV=development

# =============================================================================
# Client (Vite) — build-time / dev server
# =============================================================================

# Optional shell title (wire in App when used).
# VITE_APP_TITLE=Prime Blotter

# Blotter live WebSocket URL.
# Local: omit — PrimeBlotterApp uses relative `/blotter-stream` (Vite proxies).
# Prod (split origin): full wss URL, e.g. wss://api.example.com/blotter-stream
# VITE_BLOTTER_WS_URL=wss://api.example.com/blotter-stream

# HTTP origin for REST calls (orders bootstrap, audit, NLP, trade-booking).
# Local: omit — same-origin `/orders`, `/audit`, `/nlp` (Vite proxy).
# Prod (split origin): e.g. https://api.example.com (no trailing slash).
# VITE_BLOTTER_HTTP_URL=https://api.example.com

# =============================================================================
# Server — HTTP
# =============================================================================

# Port for Express + WebSocket. Cloud Run sets PORT automatically — do not
# hardcode in Dockerfile CMD.
# PORT=8000

# =============================================================================
# Server — PostgreSQL (required whenever the API uses the DB)
# =============================================================================

# Connection URL for node-pg (server/src/db/connection.ts). Required at
# server startup if anything imports the pool.
#
# Local (TCP) — uncomment and adjust user/password/db:
# DATABASE_URL=postgres://flowdesk_app:change_me@127.0.0.1:5432/flowdesk
#
# GCP Cloud Run + Cloud SQL (attach the instance to the Cloud Run service).
# Unix socket via `host` query param; example:
#   postgres://USER:PASSWORD@/DBNAME?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
# URL-encode special characters in USER or PASSWORD. Prefer Secret Manager in prod.
#
# Cloud SQL with “SSL only” over public IP: add `?sslmode=require` (or `verify-full`)
# to DATABASE_URL and point Node at the instance Server CA PEM (download from console):
#   DATABASE_SSL_CA=/absolute/path/to/server-ca.pem
# (Alternatively set libpq-style PGSSLROOTCERT to the same path.)
#
# If DATABASE_URL uses localhost/127.0.0.1 (Cloud SQL Auth Proxy), TLS must use SNI with the
# instance’s certificate hostname (SAN), not “localhost”. Set:
#   DATABASE_SSL_SERVERNAME=….REGION.sql.goog
# (Same value if you connect by public IP but the cert only lists that DNS name.)

# Optional pool tuning (server/src/db/connection.ts).
# PG_POOL_MAX=10
# PG_IDLE_TIMEOUT_MS=30000
# PG_CONNECT_TIMEOUT_MS=5000

# =============================================================================
# Server — OpenAI (NLP filter, breach insight, trade-booking agent)
# =============================================================================
# Never expose these to the frontend; server-only.

# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_ORG_ID=
# OPENAI_PROJECT_ID=
# OPENAI_TIMEOUT_MS=45000

# =============================================================================
# Server — Trade booking agent limits (optional overrides)
# =============================================================================
# See server/src/nlp/tradeBooking/tools/constants.ts

# TRADE_BOOKING_MAX_QTY=1000000
# TRADE_BOOKING_MAX_NOTIONAL_USD=50000000
# TRADE_BOOKING_PRICE_BAND_PCT=0.15

# =============================================================================
# Future / not wired yet
# =============================================================================
# VITE_INSIGHTS_API_URL=http://localhost:4100
