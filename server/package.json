{
  "name": "flowdesk-server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json && mkdir -p dist/db/migrations && cp src/db/migrations/*.sql dist/db/migrations/",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:prod": "node dist/db/migrate.js",
    "test": "tsx --test src/nlp/tradeBooking/tools/validators.test.ts"
  },
  "dependencies": {
    "@flowdesk/shared": "file:../shared",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "openai": "^6.36.0",
    "pg": "^8.20.0",
    "ws": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2"
  }
}
